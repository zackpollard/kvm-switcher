# BMC passwords — one per server, matching credential_env in servers.yaml
BMC_PASSWORD_SERVER1=changeme
BMC_PASSWORD_SERVER2=changeme

# Optional: OIDC client secret (if OIDC is enabled in servers.yaml)
# OIDC_CLIENT_SECRET=your-secret-here

# Grafana admin credentials (defaults to admin/admin)
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
